rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validation helpers
    function isValidUser(data) {
      return data.userId == request.auth.uid
        && data.email is string
        && data.email.size() <= 100;
    }

    function isValidTask(data) {
      return data.userId == request.auth.uid
        && data.goal is string
        && data.goal.size() <= 500
        && data.status is string
        && (data.status == 'pending' || data.status == 'completed');
    }

    function isValidPlan(data) {
      return data.userId == request.auth.uid
        && data.type is string
        && (data.type == 'daily' || data.type == 'rescue')
        && data.focus is string
        && data.focus.size() <= 500;
    }

    function isValidChatSession(data) {
      return data.userId == request.auth.uid
        && data.messages is list;
    }

    // Default catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for Users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time;
      allow delete: if isOwner(userId);
    }

    // Rules for Tasks collection
    match /tasks/{taskId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(taskId) && isValidTask(incoming()) && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && isValidId(taskId) && existing().userId == request.auth.uid;
    }

    // Rules for Plans collection
    match /plans/{planId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(planId) && isValidPlan(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(planId) && isValidPlan(incoming()) && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && isValidId(planId) && existing().userId == request.auth.uid;
    }

    // Rules for Chat Sessions collection
    match /chats/{chatId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(chatId) && isValidChatSession(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(chatId) && isValidChatSession(incoming()) && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && isValidId(chatId) && existing().userId == request.auth.uid;
    }
  }
}
